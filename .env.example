# Copy to .env.local and adjust as needed. All variables are optional.

# --- Google Sheets data source ---
# Override the default gviz CSV endpoints (otherwise the built-in sheet IDs are used).
# SHEETS_CURSOS_URL=
# SHEETS_VIDEOS_URL=

# Hourly refresh of the Sheets data in production (ISR revalidate).
#   true  (default) -> re-fetch at most once per hour
#   false | 0 | off | no -> disable hourly refresh; data cached until next deploy
# In development the data is always fetched fresh regardless of this value.
SHEETS_HOURLY_REVALIDATE=true

# --- Site mode ---
# Set to "true" to show the maintenance page instead of the landing.
MAINTENANCE_MODE=false
