# Copy to .env.local and adjust as needed. All variables are optional.

# --- Google Sheets data source ---
# Override the default gviz CSV endpoints (otherwise the built-in sheet IDs are used).
# SHEETS_CURSOS_URL=
# SHEETS_VIDEOS_URL=

# Live client-side refresh: when "true", an already-open page re-fetches the
# Sheets data (courses & videos) on an interval and updates in place — no page
# reload needed. When unset/false, data loads once per visit (still refreshed
# server-side via ISR ~hourly). Must be NEXT_PUBLIC_ to reach the browser.
NEXT_PUBLIC_SHEETS_LIVE_REFRESH=false
# Poll interval in minutes for the live refresh above (default 60).
# NEXT_PUBLIC_SHEETS_REFRESH_INTERVAL_MINUTES=60

# --- Site mode ---
# Set to "true" to show the maintenance page instead of the landing.
MAINTENANCE_MODE=false
